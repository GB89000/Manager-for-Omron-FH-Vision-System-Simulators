<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="MyBorderText">#FF000000</SolidColorBrush>
    <SolidColorBrush x:Key="MyBackLight">#FF008080</SolidColorBrush>
    <SolidColorBrush x:Key="ButtonBorder">#FF000000</SolidColorBrush>
    <!--<SolidColorBrush x:Key="ButtonClose.MouseOver.Border" Color="Black"/>-->

    <RadialGradientBrush 
        x:Key="ButtonRatialGreen"   
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FF00FF00" Offset="0" />
            <GradientStop Color="#FF00e100" Offset="0.2" />
            <GradientStop Color="#FF00af00" Offset="0.5" />
            <GradientStop Color="#FF007d00" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
         x:Key="ButtonRatialRed" 
         GradientOrigin="0.5,0.5" 
         Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FFFF0000" Offset="0" />
            <GradientStop Color="#FFe10000" Offset="0.2" />
            <GradientStop Color="#FFaf0000" Offset="0.5" />
            <GradientStop Color="#FF7d0000" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
        x:Key="ButtonRatialBlue"    
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FF0000FF" Offset="0" />
            <GradientStop Color="#FF0000e1" Offset="0.2" />
            <GradientStop Color="#FF0000af" Offset="0.5" />
            <GradientStop Color="#FF00007d" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
        x:Key="ButtonRatialBlueMidle"    
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FF4070FF" Offset="0" />
            <GradientStop Color="#FF3066FF" Offset="0.2" />
            <GradientStop Color="#FF1750Cf" Offset="0.5" />
            <GradientStop Color="#FF1750Ad" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
        x:Key="ButtonRatialBlueLight"    
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8"
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FF27B0F5" Offset="0" />
            <GradientStop Color="#FF27B0D1" Offset="0.2" />
            <GradientStop Color="#FF27B0Cf" Offset="0.5" />
            <GradientStop Color="#FF27B0Ad" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
        x:Key="ButtonRatialGold"    
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FFFFCC95" Offset="0" />
            <GradientStop Color="#FFFFCC80" Offset="0.2" />
            <GradientStop Color="#FFFFCC40" Offset="0.5" />
            <GradientStop Color="#FFFFCC00" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <RadialGradientBrush 
        x:Key="ButtonRatialWhite"    
        GradientOrigin="0.5,0.5" 
        Center="0.5,0.5" 
        RadiusX="0.8" 
        RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#FFe1e1e1" Offset="0.2" />
            <GradientStop Color="#FFafafaf" Offset="0.5" />
            <GradientStop Color="#FF7d7d7d" Offset="0.75" />
            <GradientStop Color="DimGray" Offset="1" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <Style TargetType="Label" x:Key="CommonLabelStyle">
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,-10,0,0"/>
    </Style>
</ResourceDictionary>                  