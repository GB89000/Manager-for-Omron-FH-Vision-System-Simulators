<Window x:Class="ManagerForOmronFHVisionSystemSimulators.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Height="400" Width="800" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="StyleAndGrafics\ButtonColors.xaml"/>
                <ResourceDictionary Source="StyleAndGrafics\ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border x:Name="MessageBorder"
                Background="#222222" BorderBrush="Red" BorderThickness="3" 
                CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Padding="20" MaxWidth="780">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Fehler" Foreground="Red" 
                           FontSize="35" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                <TextBlock x:Name="MessageText" Text="Hier steht die Nachricht." Foreground="White" 
                           FontSize="25" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>

                <Button x:Name="OK" Content="OK" Width="100" Height="50" Click="OkButton_Click"
                        Style="{StaticResource ButtonStyleRed}"
                        FontSize="25"
                        FontWeight="Medium"
                        IsDefault="True"
                        IsCancel="True">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>