<Window x:Class="NamespaceSettingsXAML.ProgrammSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NamespaceSettingsXAML"
        mc:Ignorable="d"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="Settings" 
        Left="250"
        Top="50"
        Width="1700" 
        Height="450" 
        >

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="StyleAndGrafics\ButtonColors.xaml"/>
                <ResourceDictionary Source="StyleAndGrafics\ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Style>
        <Style/>
    </Window.Style>

    <Border CornerRadius="15" BorderThickness="3" BorderBrush="Black" Background="Black">
        <Border CornerRadius="10" BorderThickness="5"  >
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush >
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid x:Name="Main_Grid">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#555555" Offset="0.0"/>
                        <GradientStop Color="#333333" Offset="0.5"/>
                        <GradientStop Color="#555555" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/> 
                    <RowDefinition Height="100"/> 
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="14*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Label
                    x:Name="LabelSettings"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="60"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Lime" 
                    Grid.ColumnSpan="2"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                    Settings
                </Label>

                <Label
                    x:Name="Resolution"
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="30"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" 
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center">
                    Resolution:
                </Label>

                <ComboBox Name="ColorComboBox"
                      Grid.Row="2"
                      Grid.Column="1"
                      Foreground="Black"
                      SelectionChanged="ColorComboBox_SelectionChanged" 
                      Opacity="0.5"
                      FontSize="25"
                      Margin="5,5,5,5"
                      VerticalContentAlignment="Center">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="LightGray"/>
                            <Setter Property="Margin" Value="0"/>
                            <Style.Triggers>
                                <!-- Hover-Effekt -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Red"/>
                                </Trigger>
                                <!-- Ausgewähltes Item -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="LightGray"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>




                <Label
                    x:Name="SimulatorPath"
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="30"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" 
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center">
                    Simulator Path:
                </Label>
                <TextBox
                    x:Name="PathSimulatorTextBox"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5,5,5,5"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center">
                </TextBox>
                <Button
                    x:Name="BrowseSimulatorButton" 
                    Style="{StaticResource ButtonStyleRed}"
                    Click="BrowseSimulatorButton_Click"
                    FontSize="25"
                    FontWeight="Medium"
                    Grid.Row="3"
                    Grid.Column="2"
                    Margin="5,0,5,0"
                    Focusable="False"
                    Width="150"
                    Height="40"
                    Content="Browse">
                </Button>

                <Label
                    x:Name="SimulatorsPathLabel"
                    Grid.Row="4"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="30"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" 
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center">
                    Simulators Path:
                </Label>
                <TextBox
                    x:Name="PathSimulatorsTextBox"
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="5,5,5,5"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center">
                </TextBox>
                <Button
                    x:Name="BrowseSimulatorsButton" 
                    Style="{StaticResource ButtonStyleRed}"
                    Click="BrowseSimulatorsButton_Click"
                    FontSize="25"
                    FontWeight="Medium"
                    Grid.Row="4"
                    Grid.Column="2"
                    Margin="5,0,5,0"
                    Focusable="False"
                    Width="150"
                    Height="40"
                    Content="Browse">
                </Button>

                <Label
                    x:Name="SimulatorsBackupPathLabel"
                    Grid.Row="5"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="30"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" 
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center">
                    Simulators Backup Path:
                </Label>
                <TextBox
                    x:Name="PathSimulatorBackupsTextBox"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="5,5,5,5"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center">
                </TextBox>
                <Button
                    x:Name="BrowseSimulatorsBackupButton" 
                    Style="{StaticResource ButtonStyleRed}"
                    Click="BrowseSimulatorsBackupsButton_Click"
                    FontSize="25"
                    FontWeight="Medium"
                    Grid.Row="5"
                    Grid.Column="2"
                    Margin="5,0,5,0"
                    Focusable="False"
                    Width="150"
                    Height="40"
                    Content="Browse">
                </Button>





                <Grid x:Name="OK_Cancel_Grid"
                    Grid.Row="6"
                    Grid.Column="1"
                    >
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="OK" 
                        Style="{StaticResource ButtonStyleRed}"
                        Click="OK_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        >OK
                    </Button>

                    <Button
                        x:Name="Cancel" 
                        Style="{StaticResource ButtonStyleRed}"
                        Click="Cancel_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="1"
                        >Cancel
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
