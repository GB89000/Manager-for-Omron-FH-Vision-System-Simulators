<Window x:Class="ManagerForOmronFHVisionSystemSimulators.CustomMessageBoxYesNo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Height="1000" Width="1580" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border x:Name="MessageBorder"
            CornerRadius="10" BorderThickness="3" BorderBrush="Red" Background="Red" 
            VerticalAlignment="Center" HorizontalAlignment="Center" 
            MaxWidth="1580"
            >
        <Border CornerRadius="10" Padding="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Fehler" Foreground="Red" 
                               FontSize="35" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="MessageText" Text="Hier steht die Nachricht." Foreground="White" 
                               FontSize="25" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="BtnYes" Content="Yes" Width="120" Height="50" 
                            Click="YesButton_Click"
                            Style="{StaticResource ButtonStyleRed}"
                            FontSize="25" FontWeight="Medium"
                            IsDefault="True" Margin="0,0,10,0"/>
                        <Button x:Name="BtnNo" Content="No" Width="120" Height="50" 
                            Click="NoButton_Click"
                            Style="{StaticResource ButtonStyleRed}"
                            FontSize="25" FontWeight="Medium"
                            IsCancel="True" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>