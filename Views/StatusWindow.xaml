<Window x:Class="ManagerForOmronFHVisionSystemSimulators.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" 
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" 
        Background="Transparent"
        Title="Status"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border x:Name="LoadingBorder"
            CornerRadius="10" BorderThickness="3" BorderBrush="Lime" Background="Lime" 
            VerticalAlignment="Center" HorizontalAlignment="Center" 
            MaxWidth="680"
            >
        <Border CornerRadius="10" Padding="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading..." 
                           Foreground="Lime" 
                           FontSize="35" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait..." 
                           Foreground="White" 
                           FontSize="20"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" 
                             Width="400" 
                             Height="25" 
                             Margin="0,10,0,10" 
                             Foreground="Lime"
                             Background="#333333"
                             BorderThickness="1"/>
            </StackPanel>
        </Border>
    </Border>
</Window>