<UserControl x:Class="ManagerForOmronFHVisionSystemSimulators.Views.SimulatorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManagerForOmronFHVisionSystemSimulators.Views"
             xmlns:viewmodels="clr-namespace:ManagerForOmronFHVisionSystemSimulators.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:SimulatorsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1929">
    <Grid>
        <ListView x:Name="SimulatorsListView" 
            ScrollViewer.VerticalScrollBarVisibility="Visible" 
            ItemsSource="{Binding SimulatorsList}"
            SelectedItem="{Binding SelectedSimulator, Mode=TwoWay}"
            Background="#333333" 
            Foreground="White"
            BorderThickness="0"
            FontSize ="25"
            Margin="0,0,0,0"
            SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0,8"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#444444"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#555555"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#555555"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40" HeaderContainerStyle="{StaticResource RedHeaderStyle}">
                        <GridViewColumn.Header>
                            <CheckBox Content="✖" 
                                Foreground="Lime" 
                                FontWeight="ExtraBold"
                                Style="{StaticResource {x:Static ToolBar.CheckBoxStyleKey}}"
                                IsChecked="{Binding IsAllSelected, UpdateSourceTrigger=PropertyChanged}" />
                        </GridViewColumn.Header>

                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.7" ScaleY="1.7" />
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="210"
                        HeaderContainerStyle="{StaticResource RedHeaderStyle}"
                        DisplayMemberBinding="{Binding Date, StringFormat=\{0:dd.MM.yyyy HH:mm\}}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="Date" 
                                  Command="{Binding SortCommand}" 
                                  CommandParameter="Date"/>
                        </GridViewColumn.Header>
                        </GridViewColumn>

                    <GridViewColumn Width="1645"
                        HeaderContainerStyle="{StaticResource RedHeaderStyle}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="Name" 
                              Command="{Binding SortCommand}" 
                              CommandParameter="Name"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" 
                                    TextTrimming="CharacterEllipsis" 
                                    ToolTip="{Binding Name}" 
                                    ToolTipService.InitialShowDelay="250"
                                    ToolTipService.BetweenShowDelay="0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
