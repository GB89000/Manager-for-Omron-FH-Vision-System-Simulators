<Window x:Class="ManagerForOmronFHVisionSystemSimulators.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" 
        MinWidth="400" MinHeight="150" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual" 
        SizeToContent="WidthAndHeight">

    <Border x:Name="MessageBorder"
            CornerRadius="10" BorderThickness="3" BorderBrush="Red" Background="Red" 
            VerticalAlignment="Center" HorizontalAlignment="Center" 
            MaxWidth="580"
            >
        <Border CornerRadius="10" Padding="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Fehler" Foreground="Red" 
                               FontSize="35" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="MessageText" Text="Hier steht die Nachricht." Foreground="White" 
                               FontSize="25" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                    <Button x:Name="OK" Content="OK" Width="100" Height="50" Click="OkButton_Click"
                            Style="{StaticResource ButtonStyleRed}"
                            FontSize="25"
                            FontWeight="Medium"
                            IsDefault="True"
                            IsCancel="True">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>